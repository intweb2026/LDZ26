SITE_DOMAIN=https://www.yourdomain.com

# Django & JWT
SECRET_KEY=your-django-secret-key
JWT_SECRET_KEY=your-jwt-secret-key

# CSRF & CORS (comma-separated)
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:3000,https://www.yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:8000,https://www.yourdomain.com

# Database
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=your_db_host
DB_PORT=5432

# Stripe
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# Zoho & CRM
ZOHO_WEBHOOK_URL=https://flow.zoho.in/...
CRM_WEBHOOK_URL=https://app.iq-hub.com/api/webhooks/ingest/
CRM_API_KEY=your_crm_api_key

# Email
EMAIL_HOST_USER=your@email.com
EMAIL_HOST_PASSWORD=your_app_password
